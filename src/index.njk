---
layout: layouts/base.njk
title: Home
---

{% for post in collections.writings %}
<article class="article-card">
    <div class="article-meta">
        <span class="article-date">{{ post.data.date }}</span>
        {% if post.data.category %}
          {% if post.data.category.length %}
            {% for cat in post.data.category %}
            <span class="article-category">{{ cat }}</span>
            {% endfor %}
          {% else %}
          <span class="article-category">{{ post.data.category }}</span>
          {% endif %}
        {% endif %}
        {% if post.data.lang %}
        <span class="article-lang">{{ post.data.lang }}</span>
        {% endif %}
    </div>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}
    <p>{{ post.data.description }}</p>
    {% endif %}
    <a href="{{ post.url }}" class="read-more">Continua a leggere →</a>
</article>
{% endfor %}

{% for item in collections.curated %}
<article class="article-card">
    <div class="article-meta">
        <span class="article-date">{{ item.data.date }}</span>
        <span class="article-type">🔗 CURATED</span>
        {% if item.data.source %}
        <span class="curated-source">{{ item.data.source }}</span>
        {% endif %}
    </div>
    <h2><a href="{{ item.data.external_url }}" target="_blank">{{ item.data.title }} ↗</a></h2>
    {% if item.data.description %}
    <p>{{ item.data.description }}</p>
    {% endif %}
    <a href="{{ item.data.external_url }}" target="_blank" class="read-more">Vai al link ↗</a>
</article>
{% endfor %}